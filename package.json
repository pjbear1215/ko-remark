{
  "name": "ko-remark",
  "version": "0.0.1",
  "description": "ko-remark - reMarkable Hangul input web installer",
  "author": "",
  "license": "MIT",
  "keywords": [
    "remarkable",
    "hangul",
    "korean",
    "setup"
  ],
  "bin": {
    "ko-remark": "./bin/cli.js"
  },
  "files": [
